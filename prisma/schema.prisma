generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/// Plant / facility (multi-site)
model Site {
  id                       Int                   @id @default(autoincrement())
  name                     String                @unique
  password_hash            String
  site_admin_password_hash String?
  contact_email            String
  is_disabled              Boolean               @default(false)
  paywall_enabled          Boolean               @default(false)
  paywall_price            Decimal               @default(0) @db.Decimal(10, 2)
  billing_cycle            String                @default("monthly")
  free_trial_days          Int                   @default(14)
  free_trial_preset        String?
  paywall_paid             Boolean               @default(false)
  trial_started_at         DateTime?
  /// Operation mode: checkout | inventory | full | consumables
  preset                   String                @default("checkout")
  created_at               DateTime              @default(now())
  updated_at               DateTime              @updatedAt
  employees                Employee[]
  tools                    Tool[]
  materials                Material[]
  tool_transactions        ToolTransaction[]
  material_transactions    MaterialTransaction[]
  audit_logs               AuditLog[]
  settings                 Setting[]
  update_logs              UpdateLog[]
  password_reset_tokens    PasswordResetToken[]
  reports                  Report[]

  @@map("sites")
}

/// Password reset tokens (email/link flow stub)
model PasswordResetToken {
  id         Int      @id @default(autoincrement())
  site_id    Int
  site       Site     @relation(fields: [site_id], references: [id], onDelete: Cascade)
  token_hash String   @unique
  expires_at DateTime
  used_at    DateTime?
  created_at DateTime @default(now())

  @@index([site_id])
  @@map("password_reset_tokens")
}

/// Employee Directory
model Employee {
  id                    Int                   @id @default(autoincrement())
  site_id               Int
  site                  Site                  @relation(fields: [site_id], references: [id], onDelete: Cascade)
  badge_id              String
  raw_badge_data        String
  name                  String
  job_title             String?
  created_at            DateTime              @default(now())
  updated_at            DateTime              @updatedAt
  tool_transactions     ToolTransaction[]
  material_transactions MaterialTransaction[]

  @@unique([site_id, badge_id])
  @@index([site_id])
  @@map("employees")
}

/// Tool Inventory
model Tool {
  id                   Int               @id @default(autoincrement())
  site_id              Int
  site                 Site              @relation(fields: [site_id], references: [id], onDelete: Cascade)
  tool_id              String
  name                 String
  category             String?
  location             String?
  status               String            @default("Available")
  last_checked_out_by  String?
  condition            String?           @default("Good")
  notes                String?
  checkout_time        DateTime?
  auto_status          String?
  overdue_since        DateTime?
  created_at           DateTime          @default(now())
  updated_at           DateTime          @updatedAt
  tool_transactions    ToolTransaction[]

  @@unique([site_id, tool_id])
  @@index([site_id])
  @@map("tools")
}

/// Tool Transactions
model ToolTransaction {
  id             Int      @id @default(autoincrement())
  site_id        Int
  site           Site     @relation(fields: [site_id], references: [id], onDelete: Cascade)
  transaction_id String
  occurred_at    DateTime
  badge_id       String
  employee_id    Int?
  employee       Employee? @relation(fields: [employee_id], references: [id])
  employee_name  String?
  tool_id        String
  tool           Tool     @relation(fields: [site_id, tool_id], references: [site_id, tool_id])
  tool_name      String?
  action         String
  purpose        String?
  created_at     DateTime @default(now())
  updated_at     DateTime @updatedAt

  @@unique([site_id, transaction_id])
  @@index([site_id])
  @@index([badge_id])
  @@index([tool_id])
  @@map("tool_transactions")
}

/// Material Inventory
model Material {
  id                    Int                   @id @default(autoincrement())
  site_id               Int
  site                  Site                  @relation(fields: [site_id], references: [id], onDelete: Cascade)
  material_id           String
  name                  String
  category              String?
  unit                  String?
  location              String?
  current_qty           Float                 @default(0)
  min_qty               Float                 @default(0)
  status                String                @default("OK")
  last_taken_by         String?
  notes                 String?
  low_stock_email_sent  Boolean               @default(false)
  low_stock_email_date  DateTime?
  low_stock_email_to    String?
  created_at            DateTime              @default(now())
  updated_at            DateTime              @updatedAt
  material_transactions MaterialTransaction[]

  @@unique([site_id, material_id])
  @@index([site_id])
  @@map("materials")
}

/// Material Transactions
model MaterialTransaction {
  id             Int       @id @default(autoincrement())
  site_id        Int
  site           Site      @relation(fields: [site_id], references: [id], onDelete: Cascade)
  transaction_id String
  occurred_at    DateTime
  badge_id       String
  employee_id    Int?
  employee       Employee? @relation(fields: [employee_id], references: [id])
  employee_name  String?
  material_id    String
  material       Material  @relation(fields: [site_id, material_id], references: [site_id, material_id])
  material_name  String?
  qty_taken      Float
  unit           String?
  remaining_qty  Float?
  created_at     DateTime  @default(now())
  updated_at     DateTime  @updatedAt

  @@unique([site_id, transaction_id])
  @@index([site_id])
  @@index([badge_id])
  @@index([material_id])
  @@map("material_transactions")
}

/// Security & Audit log
model AuditLog {
  id          Int      @id @default(autoincrement())
  site_id     Int?
  site        Site?    @relation(fields: [site_id], references: [id], onDelete: SetNull)
  audit_id    String   @unique
  occurred_at DateTime
  changed_by  String?
  tool_id     String?
  change_type String?
  notes       String?
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  @@index([site_id])
  @@map("audit_logs")
}

/// Settings (null site_id = global/master)
model Setting {
  id         Int      @id @default(autoincrement())
  site_id    Int?
  site       Site?    @relation(fields: [site_id], references: [id], onDelete: Cascade)
  key        String
  value      String
  notes      String?
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@unique([site_id, key])
  @@index([site_id])
  @@map("settings")
}

/// Updates sheet change log
model UpdateLog {
  id            Int      @id @default(autoincrement())
  site_id       Int?
  site          Site?    @relation(fields: [site_id], references: [id], onDelete: Cascade)
  update_number Int
  event_date    DateTime
  description   String
  updated_by    String?
  created_at    DateTime @default(now())
  updated_at    DateTime @updatedAt

  @@index([site_id])
  @@map("update_logs")
}

/// Scheduled inventory digests (daily / weekly)
model Report {
  id           Int      @id @default(autoincrement())
  site_id      Int
  site         Site     @relation(fields: [site_id], references: [id], onDelete: Cascade)
  type         String
  period_start DateTime
  period_end   DateTime
  summary      Json
  created_at   DateTime @default(now())
  updated_at   DateTime @updatedAt

  @@index([site_id])
  @@index([site_id, created_at])
  @@index([site_id, type])
  @@map("ops_reports")
}

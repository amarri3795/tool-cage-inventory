# Copy to .env and fill in real values. Never commit .env.
# Use the Neon "pooled" connection string for Vercel (port 5432, often includes -pooler).
# Vercel → Settings → Environment Variables: same key names, no quotes, then Redeploy.

DATABASE_URL="postgresql://USER:PASSWORD@HOST/neondb?sslmode=require"

# Auth / sessions (set real values in .env — never commit secrets)
SESSION_SECRET=replace-with-long-random-string-at-least-32-chars
MASTER_ADMIN_ID=your-admin-id
MASTER_ADMIN_PASSWORD=your-admin-password
DEFAULT_SITE_PASSWORD=your-site-password
# Optional; if unset, seed uses {DEFAULT_SITE_PASSWORD}Admin
# DEFAULT_SITE_ADMIN_PASSWORD=your-site-admin-password

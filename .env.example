# Copy to .env and fill in your Neon connection string.
# Use the Neon "pooled" connection string for Vercel (port 5432, often includes -pooler).

DATABASE_URL="postgresql://USER:PASSWORD@HOST/neondb?sslmode=require"

# Auth / sessions (set real values in .env — never commit secrets)
SESSION_SECRET=replace-with-at-least-32-random-characters
MASTER_ADMIN_ID=your-admin-id-here
MASTER_ADMIN_PASSWORD=your-secure-password-here
DEFAULT_SITE_PASSWORD=ChangeMeSite1!
